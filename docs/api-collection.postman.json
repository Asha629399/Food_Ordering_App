{
  "info": {
    "name": "Restaurant Food Ordering API",
    "description": "API collection for the Restaurant Food Ordering App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nick_fury\",\n  \"password\": \"fury123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "List Restaurants",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Restaurant by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": 1,\n  \"items\": [\n    { \"menuItemId\": 1, \"quantity\": 2 },\n    { \"menuItemId\": 3, \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Place Order (Admin/Manager only)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/orders/1/place",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethodId\": 1\n}"
            }
          }
        },
        {
          "name": "Cancel Order (Admin/Manager only)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/orders/1/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "List Payment Methods",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/payments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Payment Method",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/payments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"card\",\n  \"label\": \"Visa ending 9999\"\n}"
            }
          }
        },
        {
          "name": "Update Payment Method (Admin only)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/payments/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Visa ending 1111\"\n}"
            }
          }
        },
        {
          "name": "Delete Payment Method (Admin only)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/payments/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
